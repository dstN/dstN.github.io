---

<section id="resume" class="section">
  <div class="w-wide">
    <h2>Experience</h2>
    <p style="margin-top: var(--s-sm); color: var(--ink-muted); font-size: 0.875rem;">
      10+ years of building for the web — from apprenticeship to senior frontend.
    </p>

    <div class="timeline-strip" style="margin-top: var(--s-2xl);">
      {timeline.map((entry) => (
        <div class={`timeline-card ${entry.current ? "current" : ""}`}>
          <span class="timeline-date">{entry.date}</span>
          <span class="timeline-title">
            {entry.title}
            {entry.current && <span class="badge-current">now</span>}
          </span>
          <span class="timeline-org">{entry.org}</span>
          {entry.skills.length > 0 && (
            <div class="timeline-tags">
              {entry.skills.map(s => <span class="tag">{s}</span>)}
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
