    skills: ["Vue.js", "Tailwind CSS", "Twig", "WordPress", "Docker"],
  },
  {
    title: "Front End Developer",
    org: "U. Günther GmbH",
    date: "02/2017 – 01/2018",
    skills: ["HTML", "CSS", "JavaScript", "jQuery", "WordPress"],
  },
  {
    title: "Front End Developer",
    org: "Freelancing",
    date: "10/2016 – 01/2017",
    skills: ["HTML", "CSS", "JavaScript", "WordPress"],
  },
  {
    title: "Front End Developer",
    org: "Sven Vörtmann Internet und IT Service",
    date: "10/2015 – 09/2016",
    skills: ["HTML", "CSS", "JavaScript", "Joomla"],
  },
  {
    title: "Digital Media Designer",
    org: "Zweiradcenter Melahn GmbH",
    date: "05/2015 – 09/2015",
    skills: ["Photoshop", "HTML", "CSS"],
  },
  {
